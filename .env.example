# Canonical site URL for SEO (Open Graph, sitemap.xml, robots.txt). No trailing slash.
# Production: your canonical URL (no trailing slash). If unset, defaults to https://kenworkspace.com.
NEXT_PUBLIC_SITE_URL=
# Set to "true" to hide the site from search (noindex, empty sitemap, no sitemap in robots). Direct links still work.
# NEXT_PUBLIC_BLOCK_SEARCH_INDEXING=true
# Optional: Google Search Console → tag verification (content value only, not the whole meta tag).
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Notes + shared notes: service role lets the API read others’ notes when you are the sharee.
# Without it, RLS/anon may show “shared” but the other account sees nothing.
# Auth (password / reset): use service role if RLS blocks writes to auth_users, auth_password_reset_tokens.
# Avatars (browser upload): SUPABASE_JWT_SECRET = JWT Secret in Dashboard → Settings → API (same secret Supabase uses to sign user JWTs; NOT service_role). /api/auth/storage-jwt mints a short JWT so Storage RLS sees auth.uid().
# Run migrations under supabase/migrations (e.g. 20250322100000_auth_password.sql, 20250323120000_auth_avatar_storage.sql, 20250324140000_avatar_storage_rls_and_rpc.sql, …).
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth (Google Drive via NextAuth). In Google Cloud Console → OAuth client → Authorized redirect URIs:
#   http://localhost:3000/api/drive-auth/callback/google
#   http://127.0.0.1:3000/api/drive-auth/callback/google
#   https://your-domain.com/api/drive-auth/callback/google

# Password-reset links: AUTH_APP_BASE_URL → NEXT_PUBLIC_SITE_URL → default in lib/site-url.ts (never the dev request host).
# AUTH_APP_BASE_URL=https://your-domain.com
# NEXTAUTH_URL / AUTH_URL are for other flows — see Drive OAuth comments above.

# ── Password reset email (use Resend and/or SMTP) ──
# Option A — Resend (used when RESEND_API_KEY is set): https://resend.com → API Keys → key starts with re_
# RESEND_API_KEY=re_xxxxxxxx
# Without a verified domain, Resend only delivers test mail to your Resend account email (403 for other recipients).
# Fix: (1) use forgot-password for a user whose email matches your Resend login, or (2) verify a domain at resend.com/domains and set AUTH_EMAIL_FROM to that domain.
# From address (must match Resend rules):
#   - Testing: leave AUTH_EMAIL_FROM unset → onboarding@resend.dev
#   - Production: verify domain in Resend → Domains, then e.g.:
# AUTH_EMAIL_FROM=noreply@yourdomain.com
# Optional display name: AUTH_EMAIL_FROM_NAME=Ken Workspace
# After editing .env, restart the dev server — Next loads env at startup.
# Common errors: wrong API key; from domain not verified; recipient not allowed with onboarding@resend.dev.
#
# Option B — SMTP (Gmail, etc.): use an App Password if Gmail has 2FA.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# AUTH_EMAIL_FROM=you@gmail.com
# Optional: SMTP_SECURE=true with port 465
#
# Reset links use the request origin; behind a wrong reverse-proxy host, set:
# AUTH_APP_BASE_URL=https://your-domain.com
#
# If mail is not configured, the API still returns success (anti-enumeration). The app does not open the reset page automatically — only via the email link.
#
# No mail in inbox — checklist:
# 1) Dev: use API response field debug (development only) and Resend → Emails.
# 2) Forgot-password email must match auth_users.email (username-only accounts get no mail).
# 3) Set SUPABASE_SERVICE_ROLE_KEY or the server may not read/write users/tokens.
# 4) Resend: check resend.com → Emails; check spam. With onboarding@resend.dev, recipient is usually your Resend account email unless you verify a domain.

# Optional: base URL for listening audio (e.g. Cloudflare R2). Leave empty to use local /audios/.
# Example: https://pub-xxxxxxxx.r2.dev
NEXT_PUBLIC_AUDIO_BASE_URL=
OPENAI_API_KEY=
# Chat (scoring, refine transcript, etc.). IELTS mic: whisper-1 + this model.
OPENAI_MODEL=gpt-4.1-mini
# Study Kit: default gpt-5.4 (Responses API) + medium reasoning/verbosity — speed/quality balance.
# Faster: STUDY_KIT_REASONING_EFFORT=low  |  Richer (slower): high or xhigh, STUDY_KIT_VERBOSITY=high
# Chat-only (no GPT-5): STUDY_KIT_OPENAI_MODEL=gpt-4o
# If Responses fails, server falls back: gpt-4o → gpt-4.1 → gpt-4o-mini.
# Scanned PDFs + image uploads (png/jpg/webp/gif): Vision OCR (same OPENAI_API_KEY).
# STUDY_KIT_VISION_MODEL=gpt-4o-mini   # or gpt-4o for harder scans
# STUDY_KIT_OCR_MAX_PAGES=24           # max PDF pages to rasterize + OCR per file
# STUDY_KIT_OCR_BATCH_SIZE=3           # pages per vision request (lower if API errors)
# STUDY_KIT_OCR_DESIRED_WIDTH=1100     # render width in px (lower = smaller images)
#
# Async pipeline (Netlify only, avoids sync function timeout): run scripts/sql/study_kit_summarize_jobs.sql
# and create Storage bucket `study-kit-async-jobs` (private). Then set:
# STUDY_KIT_INTERNAL_SECRET=<long random string>   # same value on Netlify for Next + Background Functions
# STUDY_KIT_ASYNC=1   # strongly recommended on production (custom domains often lack NETLIFY=true in Next runtime)
# Local dev: set STUDY_KIT_FORCE_SYNC=1 or omit STUDY_KIT_INTERNAL_SECRET to keep synchronous summarize.
# Optional override for transcript cleanup only:
# IELTS_SPEAK_REFINE_MODEL=gpt-4.1-mini

# ── Google Drive (/drive) — old or new variable names work ──
# Session secret: AUTH_SECRET or NEXTAUTH_SECRET
# Google OAuth: AUTH_GOOGLE_ID + AUTH_GOOGLE_SECRET
#   or GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET
# Production (e.g. Netlify): AUTH_URL=https://your-site.netlify.app — do not use localhost
# (OAuth would redirect to your machine). Local dev: leave AUTH_URL unset.
# Register both callback URLs in Google Cloud:
#   http://localhost:3000/api/drive-auth/callback/google
#   https://your-site.netlify.app/api/drive-auth/callback/google
# AUTH_SECRET=
# NEXTAUTH_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# NEXTAUTH_URL=http://127.0.0.1:3000

# ── LiveKit Cloud (/call) — token API uses key/secret (server only); browser needs public WSS URL
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# WSS from Project Settings
NEXT_PUBLIC_LIVEKIT_URL=

# Video: MediaRecorder in the browser → .webm download (no extra env).
# Chat .txt export: SUPABASE_SERVICE_ROLE_KEY + meets_chat_messages table (see supabase/migrations).
